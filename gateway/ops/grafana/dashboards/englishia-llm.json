{
  "uid": "englishia-llm",
  "title": "englishIA — LLM (tokens · custo · latência)",
  "tags": ["englishia", "llm", "auditoria"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Tokens totais",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum(llm_tokens_input_total) + sum(llm_tokens_output_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 2, "type": "stat", "title": "Custo estimado (USD)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum(llm_cost_usd_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 3, "type": "stat", "title": "Cache hit rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2 } },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum(llm_cache_total{result=\"hit\"}) / clamp_min(sum(llm_cache_total), 1)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 4, "type": "stat", "title": "Fallbacks acionados",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum(llm_fallback_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Tokens/s (input vs output)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "legendFormat": "input", "expr": "sum(rate(llm_tokens_input_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "output", "expr": "sum(rate(llm_tokens_output_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Custo acumulado (USD)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum(llm_cost_usd_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Latência média (s)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum(rate(llm_latency_seconds_sum[1m])) / clamp_min(sum(rate(llm_latency_seconds_count[1m])), 0.001)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Guardrails bloqueados (por código)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "legendFormat": "{{code}}", "expr": "sum by (code) (llm_guardrail_blocked_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Rota por modelo (router)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "legendFormat": "{{model}}", "expr": "sum by (model) (llm_route_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    }
  ]
}
